# ThoughtGraph — Environment Variables
# Copy this file to .env.local and fill in your values.
#
# NEVER prefix this with NEXT_PUBLIC_ — it must stay server-side only.
# It is read exclusively by src/lib/gemini.ts, which is only ever called
# from src/app/api/analyze/route.ts (a server-side API route).

GEMINI_API_KEY=your_gemini_api_key_here
